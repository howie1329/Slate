{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slate",
  "version": "0.1.0",
  "identifier": "com.howardthomas.slate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:sidecar && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Slate",
        "width": 760,
        "height": 820,
        "minWidth": 560,
        "minHeight": 620,
        "center": true,
        "visible": false
      },
      {
        "label": "popover",
        "title": "Slate",
        "width": 440,
        "height": 640,
        "minWidth": 360,
        "minHeight": 520,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/slate-ai-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
